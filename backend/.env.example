# Render deployment: leave empty to use defaults.
# All values are optional; sensible defaults are baked into settings.py.

# Comma-separated list of allowed hosts. Empty = allow all (dev-friendly for an assessment).
# RENDER_EXTERNAL_HOSTNAME=spotter-trip-planner.onrender.com

# Toggle Django debug mode.
# DEBUG=False

# SECRET_KEY should be set in production. Render injects RENDER_EXTERNAL_HOSTNAME; the app falls back to a dev key if absent.
# DJANGO_SECRET_KEY=replace-me-with-a-long-random-string
